---
import BaseLayout from '../layouts/BaseLayout.astro';
import PageHero from '../components/ui/PageHero.astro';
import SectionTitle from '../components/ui/SectionTitle.astro';
---

<BaseLayout 
  title="Estudos & Artigos | Weber F. Pereira & Advogados Associados"
  description="Estudos, artigos de informação jurídica e publicações do escritório Weber F. Pereira & Advogados Associados."
>
  <PageHero 
    title="Estudos & Artigos" 
    subtitle="Artigos de informação jurídica, modelos e debates produzidos por nossos profissionais e colaboradores."
    tagline="Conhecimento Compartilhado"
  />

  <section class="forum-section">
    <div class="container">
      
      <!-- Regulatory Warning Alert -->
      <div class="forum-regulatory-alert">
        <div class="alert-icon-box">
          <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <circle cx="12" cy="12" r="10"/>
            <line x1="12" y1="16" x2="12" y2="12"/>
            <line x1="12" y1="8" x2="12.01" y2="8"/>
          </svg>
        </div>
        <div class="alert-content-box">
          <h4 class="alert-heading">Diretrizes da Seção</h4>
          <p class="alert-text">
            Este é um espaço acadêmico colaborativo. Toda publicação ou comentário reflete a opinião de seu respectivo autor e deve seguir a ética profissional, sendo vedada a exposição de dados pessoais ou sigilo processual.
          </p>
        </div>
      </div>

      <!-- MAIN LAYOUT FEED -->
      <div class="forum-layout">
        
        <!-- Left Feed Column -->
        <div class="posts-column">
          <div class="feed-header-row">
            <SectionTitle 
              title="Publicações da Comunidade" 
              subtitle="Explore artigos e modelos de petições/contratos compartilhados."
              align="left"
            />
            <button id="btn-top-publish" class="btn-publish hidden">+ Publicar</button>
          </div>

          <!-- Feed tabs filter (Visible if logged in) -->
          <div id="feed-filter-tabs" class="feed-tabs hidden">
            <button id="tab-all-posts" class="feed-tab-btn active">Todas as Publicações</button>
            <button id="tab-saved-posts" class="feed-tab-btn">Meus Favoritos</button>
          </div>

          <!-- DYNAMIC FEED CONTAINER -->
          <div id="feed-container">
            <div class="feed-loading">
              <div class="spinner"></div>
              <p>Carregando publicações...</p>
            </div>
          </div>
        </div>

        <!-- Right Side Sidebar -->
        <aside class="forum-sidebar">
          <!-- Auth Promo Card (If Logged Out) -->
          <div id="side-promo-card" class="sidebar-card">
            <h3 class="side-card-title">Participe da Comunidade</h3>
            <p class="side-card-text">
              Faça o cadastro para poder publicar seus próprios artigos e modelos, curtir as publicações, salvar favoritos e participar das discussões!
            </p>
            <div class="side-card-actions">
              <button id="btn-side-login" class="btn btn-primary side-btn">Entrar no Portal</button>
              <button id="btn-side-register" class="btn-secondary-link">Criar nova conta</button>
            </div>
          </div>

          <!-- User Profile Card (If Logged In) -->
          <div id="side-profile-card" class="sidebar-card hidden">
            <div class="profile-header-meta">
              <img id="side-user-avatar" src="" alt="Avatar" class="side-avatar-img" />
              <div class="side-user-info">
                <h4 id="side-user-name">...</h4>
                <p id="side-user-location">...</p>
              </div>
            </div>
            <div class="side-profile-actions">
              <button id="btn-side-publish" class="btn btn-primary side-btn">+ Escrever Artigo</button>
              <button id="btn-side-logout" class="btn-secondary-link">Sair da Conta</button>
            </div>
          </div>

          <!-- Rules Card -->
          <div class="sidebar-card rules-card">
            <h3 class="side-card-title">Diretrizes da Seção</h3>
            <ul class="rules-list">
              <li>Linguagem técnica e informativa.</li>
              <li>Foco em teses acadêmicas gerais.</li>
              <li>Vedado expor dados de terceiros ou processos ativos.</li>
            </ul>
          </div>
        </aside>
      </div>

    </div>
  </section>

  <!-- 1. LOGIN MODAL -->
  <dialog id="modal-portal-login" class="modal-dialog">
    <div class="modal-content">
      <button class="modal-close-btn">&times;</button>
      <div class="modal-header">
        <h3>Entrar na Conta</h3>
        <p>Acesse para publicar, curtir e comentar no portal.</p>
      </div>
      <form id="form-modal-login" class="modal-form">
        <div class="form-group">
          <label for="login-email-cpf">CPF ou E-mail</label>
          <input type="text" id="login-email-cpf" required placeholder="Digite seu CPF ou E-mail..." class="form-input" />
        </div>
        <div class="form-group">
          <label for="login-password">Senha</label>
          <input type="password" id="login-password" required placeholder="Sua senha..." class="form-input" />
        </div>
        <div id="login-error-msg" class="modal-error-msg hidden">
          E-mail/CPF ou senha incorretos.
        </div>
        <button type="submit" class="btn btn-primary submit-btn">Entrar</button>
        <p class="switch-form-text">Não tem cadastro? <button type="button" id="switch-to-register" class="btn-link">Cadastre-se aqui</button></p>
      </form>
    </div>
  </dialog>

  <!-- 2. REGISTER MODAL -->
  <dialog id="modal-portal-register" class="modal-dialog">
    <div class="modal-content">
      <button class="modal-close-btn">&times;</button>
      <div class="modal-header">
        <h3>Criar Cadastro Colaborador</h3>
        <p>Preencha os campos para publicar estudos e modelos jurídicos.</p>
      </div>
      <form id="form-modal-register" class="modal-form">
        <div class="form-group">
          <label for="reg-name">Nome Completo</label>
          <input type="text" id="reg-name" required placeholder="Ex: Dr. Weber Fernandes Pereira" class="form-input" />
        </div>
        <div class="form-group">
          <label for="reg-email">E-mail</label>
          <input type="email" id="reg-email" required placeholder="seu-email@provedor.com" class="form-input" />
        </div>
        <div class="form-group">
          <label for="reg-password">Senha</label>
          <input type="password" id="reg-password" required placeholder="Digite uma senha..." class="form-input" />
        </div>
        <div class="form-row">
          <div class="form-group">
            <label for="reg-cidade">Cidade</label>
            <input type="text" id="reg-cidade" required placeholder="Sua cidade..." class="form-input" />
          </div>
          <div class="form-group">
            <label for="reg-estado">Estado (UF)</label>
            <input type="text" id="reg-estado" required maxlength="2" placeholder="Ex: GO" class="form-input uppercase-input" />
          </div>
        </div>
        <div class="form-group">
          <label for="reg-foto-file">Foto de Perfil (Opcional)</label>
          <input type="file" id="reg-foto-file" accept="image/*" class="form-input" />
          <div id="reg-foto-preview-container" class="hidden" style="margin-top: 8px; display: flex; align-items: center; gap: 8px;">
            <img id="reg-foto-preview" src="" style="width: 40px; height: 40px; border-radius: 50%; object-fit: cover;" />
            <span style="font-size: 0.8rem; color: var(--color-accent-green); font-weight: 700;">✓ Foto selecionada</span>
          </div>
        </div>
        <div id="register-error-msg" class="modal-error-msg hidden">
          Erro ao cadastrar. Verifique os dados.
        </div>
        <button type="submit" class="btn btn-primary submit-btn">Finalizar Cadastro</button>
        <p class="switch-form-text">Já tem cadastro? <button type="button" id="switch-to-login" class="btn-link">Entrar na conta</button></p>
      </form>
    </div>
  </dialog>

  <!-- 3. PUBLISH MODAL (NEW POST) -->
  <dialog id="modal-portal-publish" class="modal-dialog max-width-lg">
    <div class="modal-content">
      <button class="modal-close-btn">&times;</button>
      <div class="modal-header">
        <h3>Publicar Novo Conteúdo</h3>
        <p>Compartilhe um artigo, parecer ou modelo de contrato/petição com a comunidade.</p>
      </div>
      <form id="form-modal-publish" class="modal-form">
        <div class="form-row">
          <div class="form-group">
            <label for="pub-tipo">Tipo de Publicação</label>
            <select id="pub-tipo" class="form-input">
              <option value="Artigo">Artigo Acadêmico</option>
              <option value="Modelo">Modelo de Petição / Contrato</option>
              <option value="Notícia">Notícia Jurídica</option>
              <option value="Decisão">Decisão Comentada</option>
            </select>
          </div>
          <div class="form-group">
            <label for="pub-categoria">Categoria / Área</label>
            <select id="pub-categoria" class="form-input">
              <option value="Direito Civil">Direito Civil</option>
              <option value="Direito Imobiliário">Direito Imobiliário</option>
              <option value="Direito Criminal">Direito Criminal</option>
              <option value="Direito Trabalhista">Direito Trabalhista</option>
              <option value="Direito Previdenciário">Direito Previdenciário</option>
              <option value="Direito Administrativo">Direito Administrativo</option>
              <option value="Geral">Geral / Outros</option>
            </select>
          </div>
        </div>
        <div class="form-group">
          <label for="pub-titulo">Título da Publicação</label>
          <input type="text" id="pub-titulo" required placeholder="Insira o título do seu estudo ou modelo..." class="form-input" />
        </div>
        <div class="form-group">
          <label for="pub-conteudo">Conteúdo Principal</label>
          <textarea id="pub-conteudo" required placeholder="Escreva o text completo aqui. Use parágrafos claros..." class="form-input form-textarea" rows="12"></textarea>
        </div>
        <div id="publish-error-msg" class="modal-error-msg hidden">
          Ocorreu um erro ao publicar seu conteúdo.
        </div>
        <button type="submit" class="btn btn-primary submit-btn">Publicar no Site</button>
      </form>
    </div>
  </dialog>
</BaseLayout>

<script>
  // DOM Elements - Modals
  const modalLogin = document.getElementById("modal-portal-login") as HTMLDialogElement;
  const modalRegister = document.getElementById("modal-portal-register") as HTMLDialogElement;
  const modalPublish = document.getElementById("modal-portal-publish") as HTMLDialogElement;

  // DOM Elements - Forms
  const formLogin = document.getElementById("form-modal-login") as HTMLFormElement;
  const formRegister = document.getElementById("form-modal-register") as HTMLFormElement;
  const formPublish = document.getElementById("form-modal-publish") as HTMLFormElement;

  // DOM Elements - Buttons
  const btnTopPublish = document.getElementById("btn-top-publish")!;
  const btnSidePublish = document.getElementById("btn-side-publish")!;
  const btnSideLogin = document.getElementById("btn-side-login")!;
  const btnSideRegister = document.getElementById("btn-side-register")!;
  const btnSideLogout = document.getElementById("btn-side-logout")!;
  
  const switchToRegister = document.getElementById("switch-to-register")!;
  const switchToLogin = document.getElementById("switch-to-login")!;

  // DOM Elements - Sidebar cards
  const sidePromoCard = document.getElementById("side-promo-card")!;
  const sideProfileCard = document.getElementById("side-profile-card")!;
  const sideUserAvatar = document.getElementById("side-user-avatar") as HTMLImageElement;
  const sideUserName = document.getElementById("side-user-name")!;
  const sideUserLocation = document.getElementById("side-user-location")!;

  // DOM Elements - Containers
  const feedContainer = document.getElementById("feed-container")!;
  const feedFilterTabs = document.getElementById("feed-filter-tabs")!;
  const tabAllPosts = document.getElementById("tab-all-posts")!;
  const tabSavedPosts = document.getElementById("tab-saved-posts")!;
  let currentActiveTab: 'all' | 'saved' = 'all';

  // Photo upload variables
  const regFotoFileInput = document.getElementById("reg-foto-file") as HTMLInputElement;
  const regFotoPreviewContainer = document.getElementById("reg-foto-preview-container")!;
  const regFotoPreview = document.getElementById("reg-foto-preview") as HTMLImageElement;
  let compressedBase64Photo = "";

  // Current session user state
  let currentUser: any = null;

  // Initial Boot/Check session
  async function init() {
    setupModalCloses();
    await checkSession();
    await loadFeed();
  }

  // Image Compressor Helper
  function compressImage(file: File): Promise<string> {
    return new Promise((resolve, reject) => {
      const reader = new FileReader();
      reader.onload = (e) => {
        const img = new Image();
        img.onload = () => {
          const canvas = document.createElement("canvas");
          const MAX_WIDTH = 120;
          const MAX_HEIGHT = 120;
          let width = img.width;
          let height = img.height;

          // Crop/resize to square
          const size = Math.min(width, height);
          const xOffset = (width - size) / 2;
          const yOffset = (height - size) / 2;

          canvas.width = MAX_WIDTH;
          canvas.height = MAX_HEIGHT;

          const ctx = canvas.getContext("2d")!;
          ctx.drawImage(img, xOffset, yOffset, size, size, 0, 0, MAX_WIDTH, MAX_HEIGHT);

          // Convert to jpeg base64
          const dataUrl = canvas.toDataURL("image/jpeg", 0.7);
          resolve(dataUrl);
        };
        img.onerror = () => reject(new Error("Erro ao carregar a imagem."));
        img.src = e.target?.result as string;
      };
      reader.onerror = () => reject(new Error("Erro ao ler o arquivo."));
      reader.readAsDataURL(file);
    });
  }

  // File Upload listener
  regFotoFileInput.addEventListener("change", async () => {
    const file = regFotoFileInput.files?.[0];
    if (!file) {
      compressedBase64Photo = "";
      regFotoPreviewContainer.classList.add("hidden");
      return;
    }

    try {
      compressedBase64Photo = await compressImage(file);
      regFotoPreview.src = compressedBase64Photo;
      regFotoPreviewContainer.classList.remove("hidden");
    } catch (err) {
      alert("Erro ao processar imagem: " + (err as Error).message);
      regFotoFileInput.value = "";
      compressedBase64Photo = "";
      regFotoPreviewContainer.classList.add("hidden");
    }
  });

  // Setup modal closes when clicking X or clicking outside
  function setupModalCloses() {
    [modalLogin, modalRegister, modalPublish].forEach(modal => {
      const closeBtn = modal.querySelector(".modal-close-btn");
      closeBtn?.addEventListener("click", () => modal.close());
      modal.addEventListener("click", (e) => {
        if (e.target === modal) modal.close();
      });
    });
  }

  // Check user session
  async function checkSession() {
    try {
      const res = await fetch("http://localhost:3002/api/user-session", { credentials: "include" });
      const data = await res.json();
      
      if (data.loggedIn) {
        currentUser = data.user;
        showUserLoggedIn(data.user);
      } else {
        currentUser = null;
        showUserLoggedOut();
      }
    } catch (e) {
      console.error("[Session Check] Offline or error:", e);
      showUserLoggedOut();
    }
  }

  function showUserLoggedIn(user: any) {
    sidePromoCard.classList.add("hidden");
    sideProfileCard.classList.remove("hidden");
    btnTopPublish.classList.remove("hidden");
    feedFilterTabs.classList.remove("hidden");

    sideUserName.textContent = user.name;
    sideUserLocation.textContent = (user.cidade && user.estado) ? `${user.cidade} - ${user.estado}` : "Colaborador";
    sideUserAvatar.src = user.fotoUrl || `https://api.dicebear.com/7.x/initials/svg?seed=${encodeURIComponent(user.name)}`;
  }

  function showUserLoggedOut() {
    sidePromoCard.classList.remove("hidden");
    sideProfileCard.classList.add("hidden");
    btnTopPublish.classList.add("hidden");
    feedFilterTabs.classList.add("hidden");
    currentUser = null;
    switchTab('all');
  }

  // Load Collaborative Feed
  async function loadFeed() {
    try {
      const res = await fetch("http://localhost:3002/api/artigos", { credentials: "include" });
      const data = await res.json();
      
      feedContainer.innerHTML = "";
      if (!data.artigos || data.artigos.length === 0) {
        feedContainer.innerHTML = `
          <div class="empty-feed">
            <svg width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
              <path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/>
              <path d="M14 2v6h6M16 13H8M16 17H8M10 9H8"/>
            </svg>
            <p>Nenhuma publicação encontrada. Seja o primeiro a publicar!</p>
          </div>
        `;
        return;
      }

      data.artigos.forEach((artigo: any) => {
        const card = createArtigoDOM(artigo);
        feedContainer.appendChild(card);
      });

      applyFeedTabFilter();

    } catch (e) {
      console.error("[Load Feed] Error:", e);
      feedContainer.innerHTML = `
        <div class="error-feed">
          <p>Não foi possível carregar as publicações. Tente novamente mais tarde.</p>
        </div>
      `;
    }
  }

  // Generate HTML element for single article card
  function createArtigoDOM(artigo: any) {
    const isOwner = artigo.authorRole === "admin";
    const dateStr = formatDate(artigo.createdAt);
    const avatarSrc = artigo.authorFoto || `https://api.dicebear.com/7.x/initials/svg?seed=${encodeURIComponent(artigo.authorName)}`;

    const card = document.createElement("article");
    card.className = "forum-post";
    card.id = `post-${artigo.id}`;
    
    card.innerHTML = `
      <div class="post-header-author">
        <img src="${avatarSrc}" alt="${artigo.authorName}" class="post-author-img" />
        <div class="author-details">
          <div class="author-title-row">
            <span class="author-name">${artigo.authorName}</span>
            ${isOwner ? '<span class="verified-badge"><svg width="10" height="10" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3"><polyline points="20 6 9 17 4 12"/></svg> VERIFICADO</span>' : ''}
          </div>
          <span class="author-subtext">
            ${artigo.tipo} • ${artigo.authorCidade || 'Local não informado'}-${artigo.authorEstado || 'UF'} • ${dateStr}
          </span>
        </div>
      </div>

      <h3 class="post-title" data-artigo-id="${artigo.id}">${artigo.titulo}</h3>
      
      <!-- Content holder -->
      <div class="post-body-content">
        <p class="post-excerpt">${artigo.conteudo.substring(0, 240)}${artigo.conteudo.length > 240 ? '...' : ''}</p>
        <p class="post-full-text hidden">${artigo.conteudo.replace(/\\n/g, '<br>')}</p>
        ${artigo.conteudo.length > 240 ? `<button class="btn-read-more">Ler mais</button>` : ''}
      </div>

      <!-- Action buttons -->
      <div class="post-footer">
        <button class="forum-action-btn like-btn ${artigo.isLikedByMe ? 'liked' : ''}" data-artigo-id="${artigo.id}">
          <svg class="icon-thumb" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <path d="M14 9V5a3 3 0 0 0-3-3l-4 9v11h11.28a2 2 0 0 0 2-1.7l1.38-9a2 2 0 0 0-2-2.3zM7 22H4a2 2 0 0 1-2-2v-7a2 2 0 0 1 2-2h3"/>
          </svg>
          <span class="likes-count">${artigo.likesCount || 0}</span>
        </button>

        <button class="forum-action-btn comment-btn" data-artigo-id="${artigo.id}">
          <svg class="icon-comment" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"/>
          </svg>
          <span class="comments-count">${artigo.commentsCount || 0}</span>
        </button>

        <button class="forum-action-btn save-btn ${artigo.isSavedByMe ? 'saved' : ''}" data-artigo-id="${artigo.id}">
          <svg class="icon-bookmark" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <path d="M19 21l-7-5-7 5V5a2 2 0 0 1 2-2h10a2 2 0 0 1 2 2z"/>
          </svg>
        </button>

        <button class="forum-action-btn share-btn" data-artigo-id="${artigo.id}" data-artigo-title="${artigo.titulo}">
          <svg class="icon-share" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <circle cx="18" cy="5" r="3"/>
            <circle cx="6" cy="12" r="3"/>
            <circle cx="18" cy="19" r="3"/>
            <line x1="8.59" y1="13.51" x2="15.42" y2="17.49"/>
            <line x1="15.41" y1="6.51" x2="8.59" y2="10.49"/>
          </svg>
        </button>
      </div>

      <!-- Comments Container -->
      <div class="comments-section-container hidden" id="comments-box-${artigo.id}">
        <div class="comments-loader">Carregando comentários...</div>
        <div class="comments-list"></div>
        <form class="comment-input-row" data-artigo-id="${artigo.id}">
          <input type="text" placeholder="Escreva um comentário..." required class="comment-textbox" />
          <button type="submit" class="btn-send-comment">Responder</button>
        </form>
      </div>
    `;

    // Event listener to toggle read more
    const btnReadMore = card.querySelector(".btn-read-more");
    const titleHeader = card.querySelector(".post-title")!;
    const textExcerpt = card.querySelector(".post-excerpt")!;
    const textFull = card.querySelector(".post-full-text")!;
    
    function toggleFullText() {
      const isHidden = textFull.classList.contains("hidden");
      if (isHidden) {
        textFull.classList.remove("hidden");
        textExcerpt.classList.add("hidden");
        if (btnReadMore) btnReadMore.textContent = "Ler menos";
      } else {
        textFull.classList.add("hidden");
        textExcerpt.classList.remove("hidden");
        if (btnReadMore) btnReadMore.textContent = "Ler mais";
      }
    }

    btnReadMore?.addEventListener("click", toggleFullText);
    titleHeader.addEventListener("click", toggleFullText);

    // Like click event
    const likeBtn = card.querySelector(".like-btn")!;
    likeBtn.addEventListener("click", () => handleLikeClick(artigo.id));

    // Save click event
    const saveBtn = card.querySelector(".save-btn")!;
    saveBtn.addEventListener("click", () => handleSaveClick(artigo.id));

    // Comment click event
    const commentBtn = card.querySelector(".comment-btn")!;
    commentBtn.addEventListener("click", () => toggleCommentsSection(artigo.id));

    // Comment Form Submit
    const commentForm = card.querySelector(".comment-input-row") as HTMLFormElement;
    commentForm.addEventListener("submit", (e) => {
      e.preventDefault();
      const input = commentForm.querySelector(".comment-textbox") as HTMLInputElement;
      handleCommentSubmit(artigo.id, input.value.trim(), input);
    });

    // Share click event
    const shareBtn = card.querySelector(".share-btn")!;
    shareBtn.addEventListener("click", () => handleShareClick(artigo.id, artigo.titulo));

    return card;
  }

  // Like click handler
  async function handleLikeClick(artigoId: number) {
    if (!currentUser) {
      modalLogin.showModal();
      return;
    }

    try {
      const res = await fetch("http://localhost:3002/api/artigos/curtir", {
        method: "POST",
        headers: { "Content-Type": "application/json" },
        body: JSON.stringify({ artigoId }),
        credentials: "include"
      });
      const data = await res.json();
      if (res.ok && data.success) {
        // Toggle class and count in DOM
        const card = document.getElementById(`post-${artigoId}`)!;
        const likeBtn = card.querySelector(".like-btn")!;
        const countSpan = likeBtn.querySelector(".likes-count")!;
        let currentLikes = parseInt(countSpan.textContent || "0");

        if (data.liked) {
          likeBtn.classList.add("liked");
          countSpan.textContent = String(currentLikes + 1);
        } else {
          likeBtn.classList.remove("liked");
          countSpan.textContent = String(Math.max(0, currentLikes - 1));
        }
      }
    } catch (e) {
      console.error("Like toggle failed:", e);
    }
  }

  // Save click handler
  async function handleSaveClick(artigoId: number) {
    if (!currentUser) {
      modalLogin.showModal();
      return;
    }

    try {
      const res = await fetch("http://localhost:3002/api/artigos/salvar", {
        method: "POST",
        headers: { "Content-Type": "application/json" },
        body: JSON.stringify({ artigoId }),
        credentials: "include"
      });
      const data = await res.json();
      if (res.ok && data.success) {
        const card = document.getElementById(`post-${artigoId}`)!;
        const saveBtn = card.querySelector(".save-btn")!;
        if (data.saved) {
          saveBtn.classList.add("saved");
        } else {
          saveBtn.classList.remove("saved");
        }
      }
    } catch (e) {
      console.error("Save toggle failed:", e);
    }
  }

  // Share click handler
  function handleShareClick(artigoId: number, title: string) {
    const shareUrl = `${window.location.origin}/forum-juridico#post-${artigoId}`;
    
    // Attempt navigator.clipboard
    if (navigator.clipboard) {
      navigator.clipboard.writeText(shareUrl).then(() => {
        alert("Link do artigo copiado para a área de transferência!");
      }).catch(() => {
        // Fallback to prompt
        prompt("Copie o link de compartilhamento:", shareUrl);
      });
    } else {
      prompt("Copie o link de compartilhamento:", shareUrl);
    }
  }

  // Toggle comments box visibility and load
  async function toggleCommentsSection(artigoId: number) {
    const commentsBox = document.getElementById(`comments-box-${artigoId}`)!;
    const isHidden = commentsBox.classList.contains("hidden");

    if (isHidden) {
      commentsBox.classList.remove("hidden");
      await loadComments(artigoId);
    } else {
      commentsBox.classList.add("hidden");
    }
  }

  // Load comments from API
  async function loadComments(artigoId: number) {
    const commentsBox = document.getElementById(`comments-box-${artigoId}`)!;
    const loader = commentsBox.querySelector(".comments-loader")!;
    const list = commentsBox.querySelector(".comments-list")!;

    try {
      const res = await fetch(`http://localhost:3002/api/artigos/comentarios?artigoId=${artigoId}`);
      const data = await res.json();
      
      loader.classList.add("hidden");
      list.innerHTML = "";

      if (!data.comentarios || data.comentarios.length === 0) {
        list.innerHTML = `<p class="no-comments">Nenhum comentário enviado ainda.</p>`;
        return;
      }

      data.comentarios.forEach((comment: any) => {
        const item = document.createElement("div");
        item.className = "comment-item";
        const avatar = comment.userFoto || `https://api.dicebear.com/7.x/initials/svg?seed=${encodeURIComponent(comment.userName)}`;
        const dateStr = formatDate(comment.createdAt);

        item.innerHTML = `
          <img src="${avatar}" alt="${comment.userName}" class="comment-avatar" />
          <div class="comment-details">
            <div class="comment-header-row">
              <span class="comment-author">${comment.userName}</span>
              <span class="comment-meta">${comment.userCidade || 'Local'}-${comment.userEstado || 'UF'} • ${dateStr}</span>
            </div>
            <p class="comment-text">${comment.texto}</p>
          </div>
        `;
        list.appendChild(item);
      });

    } catch (e) {
      console.error("Comments load failed:", e);
      list.innerHTML = `<p class="error-comments">Erro ao carregar comentários.</p>`;
    }
  }

  // Post comment submission
  async function handleCommentSubmit(artigoId: number, texto: string, inputEl: HTMLInputElement) {
    if (!currentUser) {
      modalLogin.showModal();
      return;
    }

    if (!texto) return;

    try {
      const res = await fetch("http://localhost:3002/api/artigos/comentarios", {
        method: "POST",
        headers: { "Content-Type": "application/json" },
        body: JSON.stringify({ artigoId, texto }),
        credentials: "include"
      });
      const data = await res.json();
      if (res.ok && data.success) {
        inputEl.value = "";
        
        // Reload list and increment counts
        await loadComments(artigoId);

        const card = document.getElementById(`post-${artigoId}`)!;
        const commentBtn = card.querySelector(".comment-btn")!;
        const countSpan = commentBtn.querySelector(".comments-count")!;
        const currentCount = parseInt(countSpan.textContent || "0");
        countSpan.textContent = String(currentCount + 1);
      }
    } catch (e) {
      console.error("Failed to post comment:", e);
    }
  }

  // Date Formatter Helper
  function formatDate(isoString: string) {
    const d = new Date(isoString);
    if (isNaN(d.getTime())) return "Recente";
    
    // Show descriptive time (Jusbrasil style)
    const diffMs = new Date().getTime() - d.getTime();
    const diffMins = Math.floor(diffMs / 60000);
    const diffHours = Math.floor(diffMins / 60000 / 60);
    const diffDays = Math.floor(diffHours / 24);

    if (diffMins < 1) return "agora mesmo";
    if (diffMins < 60) return `há ${diffMins} min`;
    if (diffHours < 24) return `há ${diffHours} h`;
    if (diffDays < 30) return `há ${diffDays} dias`;
    
    return d.toLocaleDateString("pt-BR", { day: "numeric", month: "long", year: "numeric" });
  }

  // Triggers - Open login/register dialogs
  btnSideLogin.addEventListener("click", () => modalLogin.showModal());
  btnSideRegister.addEventListener("click", () => modalRegister.showModal());
  
  switchToRegister.addEventListener("click", () => {
    modalLogin.close();
    modalRegister.showModal();
  });

  switchToLogin.addEventListener("click", () => {
    modalRegister.close();
    modalLogin.showModal();
  });

  btnTopPublish.addEventListener("click", () => modalPublish.showModal());
  btnSidePublish.addEventListener("click", () => modalPublish.showModal());

  // Form submits: Login
  formLogin.addEventListener("submit", async (e) => {
    e.preventDefault();
    const errorMsg = document.getElementById("login-error-msg")!;
    errorMsg.classList.add("hidden");

    const login = (document.getElementById("login-email-cpf") as HTMLInputElement).value.trim();
    const password = (document.getElementById("login-password") as HTMLInputElement).value;

    try {
      const res = await fetch("http://localhost:3002/api/login", {
        method: "POST",
        headers: { "Content-Type": "application/json" },
        body: JSON.stringify({ login, password }),
        credentials: "include"
      });
      const data = await res.json();
      if (res.ok && data.success) {
        modalLogin.close();
        formLogin.reset();
        await checkSession();
        await loadFeed();
      } else {
        errorMsg.textContent = data.error || "CPF/E-mail ou senha incorretos.";
        errorMsg.classList.remove("hidden");
      }
    } catch (err) {
      errorMsg.textContent = "Erro ao conectar com o servidor.";
      errorMsg.classList.remove("hidden");
    }
  });

  // Form submits: Register public user
  formRegister.addEventListener("submit", async (e) => {
    e.preventDefault();
    const errorMsg = document.getElementById("register-error-msg")!;
    errorMsg.classList.add("hidden");

    const name = (document.getElementById("reg-name") as HTMLInputElement).value.trim();
    const email = (document.getElementById("reg-email") as HTMLInputElement).value.trim();
    const password = (document.getElementById("reg-password") as HTMLInputElement).value;
    const cidade = (document.getElementById("reg-cidade") as HTMLInputElement).value.trim();
    const estado = (document.getElementById("reg-estado") as HTMLInputElement).value.trim().toUpperCase();

    try {
      const res = await fetch("http://localhost:3002/api/public-register", {
        method: "POST",
        headers: { "Content-Type": "application/json" },
        body: JSON.stringify({ name, email, password, cidade, estado, fotoUrl: compressedBase64Photo }),
        credentials: "include"
      });
      const data = await res.json();
      if (res.ok && data.success) {
        modalRegister.close();
        formRegister.reset();
        compressedBase64Photo = "";
        regFotoPreviewContainer.classList.add("hidden");
        await checkSession();
        await loadFeed();
      } else {
        errorMsg.textContent = data.error || "Erro ao cadastrar usuário. Verifique as credenciais.";
        errorMsg.classList.remove("hidden");
      }
    } catch (err) {
      errorMsg.textContent = "Conexão rejeitada pelo servidor.";
      errorMsg.classList.remove("hidden");
    }
  });

  // Form submits: Create Article
  formPublish.addEventListener("submit", async (e) => {
    e.preventDefault();
    const errorMsg = document.getElementById("publish-error-msg")!;
    errorMsg.classList.add("hidden");

    const tipo = (document.getElementById("pub-tipo") as HTMLSelectElement).value;
    const categoria = (document.getElementById("pub-categoria") as HTMLSelectElement).value;
    const titulo = (document.getElementById("pub-titulo") as HTMLInputElement).value.trim();
    const conteudo = (document.getElementById("pub-conteudo") as HTMLTextAreaElement).value.trim();

    try {
      const res = await fetch("http://localhost:3002/api/artigos", {
        method: "POST",
        headers: { "Content-Type": "application/json" },
        body: JSON.stringify({ tipo, categoria, titulo, conteudo }),
        credentials: "include"
      });
      const data = await res.json();
      if (res.ok && data.success) {
        modalPublish.close();
        formPublish.reset();
        await loadFeed();
      } else {
        errorMsg.textContent = data.error || "Erro ao publicar artigo.";
        errorMsg.classList.remove("hidden");
      }
    } catch (err) {
      errorMsg.textContent = "Erro de conexão com o servidor.";
      errorMsg.classList.remove("hidden");
    }
  });

  // Handle Logout
  btnSideLogout.addEventListener("click", async () => {
    try {
      await fetch("http://localhost:3002/api/logout", { method: "POST", credentials: "include" });
    } catch (e) {
      console.warn("Logout request failed");
    }
    showUserLoggedOut();
    await loadFeed();
  });

  // Filter Feed by active tab
  function applyFeedTabFilter() {
    const cards = feedContainer.querySelectorAll(".forum-post");
    cards.forEach((card: any) => {
      if (currentActiveTab === 'all') {
        card.classList.remove("hidden");
      } else {
        const saveBtn = card.querySelector(".save-btn");
        if (saveBtn && saveBtn.classList.contains("saved")) {
          card.classList.remove("hidden");
        } else {
          card.classList.add("hidden");
        }
      }
    });

    // Handle empty state message for favorites
    let emptyMsg = feedContainer.querySelector(".empty-favorites-msg");
    const visibleCards = feedContainer.querySelectorAll(".forum-post:not(.hidden)");
    
    if (visibleCards.length === 0 && currentActiveTab === 'saved') {
      if (!emptyMsg) {
        emptyMsg = document.createElement("div");
        emptyMsg.className = "empty-favorites-msg empty-feed";
        emptyMsg.innerHTML = `
          <svg width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
            <path d="M19 21l-7-5-7 5V5a2 2 0 0 1 2-2h10a2 2 0 0 1 2 2z"/>
          </svg>
          <p>Você ainda não possui publicações salvas.</p>
        `;
        feedContainer.appendChild(emptyMsg);
      }
    } else {
      if (emptyMsg) emptyMsg.remove();
    }
  }

  // Switch tab filter handler
  function switchTab(tab: 'all' | 'saved') {
    currentActiveTab = tab;
    if (tab === 'all') {
      tabAllPosts.classList.add("active");
      tabSavedPosts.classList.remove("active");
    } else {
      tabAllPosts.classList.remove("active");
      tabSavedPosts.classList.add("active");
    }
    applyFeedTabFilter();
  }

  // Add click listeners to tabs
  tabAllPosts.addEventListener("click", () => switchTab('all'));
  tabSavedPosts.addEventListener("click", () => switchTab('saved'));

  // Start initialization
  init();
</script>

