---
import { headerMenu } from '../../data/navigation';
import { siteConfig } from '../../data/site';
---

<header class="site-header">
  <div class="container header-container">
    <a href="/" class="logo" aria-label="Weber F. Pereira & Advogados Associados - Home">
      <!-- Image structure prepared for real logo with fallback -->
      <div class="logo-wrapper">
        <img 
          src="https://i.ibb.co/twsNKD28/logosf.png" 
          alt="Logomarca Weber F. Pereira & Advogados Associados" 
          class="logo-image" 
          onerror="this.style.display='none'; document.getElementById('header-logo-fallback').style.display='flex';"
        />
        
        <!-- Temporary CSS/SVG Fallback Symbol -->
        <div id="header-logo-fallback" class="logo-fallback-visual">
          <svg class="logo-icon" viewBox="0 0 40 40" width="36" height="36" fill="none" xmlns="http://www.w3.org/2000/svg">
            <path d="M20 2L5 9v11c0 9.27 6.4 17.94 15 20 8.6-2.06 15-10.73 15-20V9L20 2z" stroke="var(--color-primary)" stroke-width="2.5" stroke-linejoin="round"/>
            <path d="M12 15h16" stroke="var(--color-accent-orange)" stroke-width="2" stroke-linecap="round"/>
            <path d="M20 11v16" stroke="var(--color-accent-green)" stroke-width="2.5" stroke-linecap="round"/>
            <path d="M16 23c0 2.2 1.8 4 4 4s4-1.8 4-4" stroke="var(--color-accent-yellow)" stroke-width="2" stroke-linecap="round"/>
            <path d="M15 15l-3 5h6l-3-5zm10 0l-3 5h6l-3-5z" fill="var(--color-accent-red)"/>
          </svg>
        </div>
      </div>
    </a>

    <!-- Hamburger Button for Mobile -->
    <button class="mobile-menu-toggle" aria-label="Abrir menu de navegação" aria-expanded="false" aria-controls="main-nav">
      <span class="hamburger-line"></span>
      <span class="hamburger-line"></span>
      <span class="hamburger-line"></span>
    </button>

    <!-- Navigation Menu -->
    <nav id="main-nav" class="main-nav">
      <ul class="nav-list">
        {headerMenu.map((item) => (
          <li class="nav-item">
            <a href={item.href} class="nav-link">{item.label}</a>
          </li>
        ))}
      </ul>
      <div class="nav-cta-mobile">
        <a href="/#fale-conosco" class="btn btn-primary btn-sm">
          Falar pelo WhatsApp
        </a>
      </div>
    </nav>

    <!-- Desktop Call to Action -->
    <div class="header-cta">
      <a href="/#fale-conosco" class="btn btn-primary">
        Falar pelo WhatsApp
      </a>
    </div>
  </div>
</header>

<script>
  const toggleBtn = document.querySelector('.mobile-menu-toggle');
  const nav = document.querySelector('.main-nav');
  const links = document.querySelectorAll('.nav-link');

  if (toggleBtn && nav) {
    toggleBtn.addEventListener('click', () => {
      const isExpanded = toggleBtn.getAttribute('aria-expanded') === 'true';
      toggleBtn.setAttribute('aria-expanded', (!isExpanded).toString());
      toggleBtn.classList.toggle('active');
      nav.classList.toggle('active');
      document.body.classList.toggle('menu-open');
    });

    // Close menu on link click
    links.forEach(link => {
      link.addEventListener('click', () => {
        toggleBtn.setAttribute('aria-expanded', 'false');
        toggleBtn.classList.remove('active');
        nav.classList.remove('active');
        document.body.classList.remove('menu-open');
      });
    });
  }
</script>

<style>
  .site-header {
    position: fixed;
    top: 0;
    left: 0;
    width: 100%;
    z-index: 1000;
    background-color: rgba(255, 255, 255, 0.85);
    backdrop-filter: blur(12px);
    border-bottom: 1px solid rgba(229, 229, 229, 0.5);
    transition: all var(--transition-normal);
  }

  .header-container {
    display: flex;
    align-items: center;
    justify-content: space-between;
    height: 80px;
    gap: 1.5rem;
    max-width: 1600px; /* Expand to 1600px to allow elements to stretch out to the left and right */
    width: 100%;
  }

  .logo {
    display: flex;
    align-items: center;
    gap: var(--space-sm);
  }

  .logo-wrapper {
    position: relative;
    display: flex;
    align-items: center;
    height: 64px;
    width: auto;
    flex-shrink: 0;
  }

  .logo-image {
    height: 100%;
    width: auto;
    max-height: 64px;
    object-fit: contain;
  }

  .logo-fallback-visual {
    display: none;
    align-items: center;
    justify-content: center;
  }

  .logo-icon {
    flex-shrink: 0;
    transition: transform var(--transition-normal);
  }

  .logo:hover .logo-icon {
    transform: rotate(-5deg) scale(1.05);
  }

  /* Main Navigation */
  .main-nav {
    display: flex;
    align-items: center;
  }

  .nav-list {
    display: flex;
    align-items: center;
    list-style: none;
    gap: 0.9rem;
  }

  .nav-link {
    font-family: var(--font-display);
    font-size: 0.75rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    color: var(--color-bg-dark);
    padding: 0.5rem 0.15rem;
    position: relative;
    white-space: nowrap;
  }

  .nav-link::after {
    content: '';
    position: absolute;
    bottom: -2px;
    left: 0;
    width: 0;
    height: 2px;
    background-color: var(--color-primary);
    transition: width var(--transition-fast);
  }

  .nav-link:hover {
    color: var(--color-primary);
  }

  .nav-link:hover::after {
    width: 100%;
  }

  .nav-cta-mobile {
    display: none;
  }

  .header-cta {
    flex-shrink: 0;
    margin-left: 0.75rem;
  }

  /* Hamburger Menu Button */
  .mobile-menu-toggle {
    display: none;
    flex-direction: column;
    justify-content: space-between;
    width: 30px;
    height: 20px;
    background: transparent;
    border: none;
    cursor: pointer;
    z-index: 1010;
  }

  .hamburger-line {
    width: 100%;
    height: 2px;
    background-color: var(--color-bg-dark);
    transition: all var(--transition-fast);
  }

  /* Responsive Styling */
  @media (min-width: 992px) and (max-width: 1400px) {
    .nav-list {
      gap: 0.5rem; /* Reduce gap to fit on small laptop screens */
    }
    .nav-link {
      font-size: 0.675rem; /* Squeeze font size slightly */
    }
    .header-container {
      gap: 0.5rem;
    }
  }

  @media (max-width: 991px) {
    .header-cta {
      display: none;
    }

    .mobile-menu-toggle {
      display: flex;
    }

    /* Mobile Nav Overlay */
    .main-nav {
      position: fixed;
      top: 0;
      right: -100%;
      width: 80%;
      max-width: 320px;
      height: 100vh;
      background-color: var(--color-bg-dark);
      padding: 100px var(--space-lg) var(--space-lg);
      flex-direction: column;
      align-items: flex-start;
      gap: var(--space-xl);
      box-shadow: var(--shadow-premium);
      transition: right var(--transition-normal);
      z-index: 1005;
    }

    .main-nav.active {
      right: 0;
    }

    .nav-list {
      flex-direction: column;
      width: 100%;
      gap: var(--space-lg);
    }

    .nav-link {
      color: var(--color-text-light);
      font-size: 1.1rem;
      width: 100%;
      display: block;
      white-space: normal;
    }

    .nav-link::after {
      display: none;
    }

    .nav-link:hover {
      color: var(--color-primary-light);
      padding-left: var(--space-xs);
    }

    .nav-cta-mobile {
      display: block;
      width: 100%;
      margin-top: var(--space-md);
    }

    .nav-cta-mobile .btn {
      width: 100%;
    }

    /* Hamburger Animation */
    .mobile-menu-toggle.active .hamburger-line:nth-child(1) {
      transform: translateY(9px) rotate(45deg);
      background-color: var(--color-text-light);
    }

    .mobile-menu-toggle.active .hamburger-line:nth-child(2) {
      opacity: 0;
    }

    .mobile-menu-toggle.active .hamburger-line:nth-child(3) {
      transform: translateY(-9px) rotate(-45deg);
      background-color: var(--color-text-light);
    }
  }

  /* Body Lock when Menu is open */
  :global(body.menu-open) {
    overflow: hidden;
  }
</style>
