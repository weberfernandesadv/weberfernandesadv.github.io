---
import { siteConfig } from '../../data/site';
import { footerLinks } from '../../data/navigation';
---

<footer class="site-footer">
  <div class="container footer-grid">
    <!-- Brand Info -->
    <div class="footer-col brand-col">
      <div class="footer-logo">
        <div class="logo-wrapper">
          <img 
            src="https://i.ibb.co/twsNKD28/logosf.png" 
            alt="Logomarca Weber F. Pereira & Advogados Associados" 
            class="logo-image" 
            onerror="this.style.display='none'; document.getElementById('footer-logo-fallback').style.display='flex';"
          />
          
          <!-- Temporary CSS/SVG Fallback Symbol -->
          <div id="footer-logo-fallback" class="logo-fallback-visual">
            <svg class="logo-icon" viewBox="0 0 40 40" width="30" height="30" fill="none" xmlns="http://www.w3.org/2000/svg">
              <path d="M20 2L5 9v11c0 9.27 6.4 17.94 15 20 8.6-2.06 15-10.73 15-20V9L20 2z" stroke="var(--color-primary)" stroke-width="2.5" stroke-linejoin="round"/>
              <path d="M12 15h16" stroke="var(--color-accent-orange)" stroke-width="2" stroke-linecap="round"/>
              <path d="M20 11v16" stroke="var(--color-accent-green)" stroke-width="2.5" stroke-linecap="round"/>
              <path d="M16 23c0 2.2 1.8 4 4 4s4-1.8 4-4" stroke="var(--color-accent-yellow)" stroke-width="2" stroke-linecap="round"/>
              <path d="M15 15l-3 5h6l-3-5zm10 0l-3 5h6l-3-5z" fill="var(--color-accent-red)"/>
            </svg>
          </div>
        </div>
      </div>

      <!-- Separar Razão Social, OAB e CNPJ -->
      <div class="legal-info-container">
        <p class="legal-info-item">
          <span class="legal-label">Razão Social:</span>
          <span class="legal-value">{siteConfig.legalName}</span>
        </p>
        <p class="legal-info-item">
          <span class="legal-label">Inscrição:</span>
          <span class="legal-value">{siteConfig.oab}</span>
        </p>
        <p class="legal-info-item">
          <span class="legal-label">CNPJ:</span>
          <span class="legal-value">{siteConfig.cnpj}</span>
        </p>
      </div>
      
      <p class="motto">{siteConfig.motto}</p>
    </div>

    <!-- Quick Links -->
    <div class="footer-col">
      <h3 class="footer-title">Navegação</h3>
      <ul class="footer-links">
        {footerLinks.map((link) => (
          <li>
            <a href={link.href} class="footer-link">{link.label}</a>
          </li>
        ))}
      </ul>
    </div>

    <!-- Contact Info -->
    <div class="footer-col contact-col">
      <h3 class="footer-title">Atendimento</h3>
      <ul class="footer-contacts">
        <li class="contact-item">
          <!-- WhatsApp Icon -->
          <svg class="contact-icon" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <path d="M21 11.5a8.38 8.38 0 0 1-.9 3.8 8.5 8.5 0 0 1-7.6 4.7 8.38 8.38 0 0 1-3.8-.9L3 21l1.9-5.7a8.38 8.38 0 0 1-.9-3.8 8.5 8.5 0 0 1 4.7-7.6 8.38 8.38 0 0 1 3.8-.9h.5a8.48 8.48 0 0 1 8 8v.5z"/>
          </svg>
          <div>
            <p class="contact-label">WhatsApp</p>
            <a href={`https://wa.me/${siteConfig.whatsappNumber}`} class="contact-value" target="_blank" rel="noopener noreferrer">
              {siteConfig.phone}
            </a>
          </div>
        </li>
        <li class="contact-item">
          <!-- Email Icon -->
          <svg class="contact-icon" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/>
            <polyline points="22,6 12,13 2,6"/>
          </svg>
          <div>
            <p class="contact-label">E-mail</p>
            <a href={`mailto:${siteConfig.email}`} class="contact-value">
              {siteConfig.email}
            </a>
          </div>
        </li>
        <li class="contact-item">
          <!-- Map Pin Icon -->
          <svg class="contact-icon" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"/>
            <circle cx="12" cy="10" r="3"/>
          </svg>
          <div>
            <p class="contact-label">Endereço</p>
            <a href={siteConfig.addressLink} class="contact-value address-value" target="_blank" rel="noopener noreferrer">
              {siteConfig.address}
            </a>
          </div>
        </li>
      </ul>
    </div>
  </div>

  <div class="footer-bottom">
    <div class="container bottom-container">
      <p class="copyright">
        &copy; {new Date().getFullYear()} {siteConfig.name}. Todos os direitos reservados.
      </p>
      <p class="developer-credit">
        Desenvolvido por <a href="https://cognicaodigittal.com/" target="_blank" rel="noopener noreferrer" class="developer-link">Cognição Digital</a>
      </p>
      <p class="ethical-notice">
        Comunicação institucional em conformidade com o Provimento 205/2021 do CFOAB.
      </p>
    </div>
  </div>
</footer>

<style>
  .site-footer {
    background-color: var(--color-bg-dark);
    color: var(--color-text-muted-light);
    padding: var(--space-xxl) 0 0;
    border-top: 2px solid var(--color-primary);
  }

  .footer-grid {
    display: grid;
    grid-template-columns: 1.5fr 1fr 1.5fr;
    gap: var(--space-xl);
    padding-bottom: var(--space-xl);
  }

  .footer-col {
    display: flex;
    flex-direction: column;
    gap: var(--space-md);
  }

  .brand-col {
    gap: var(--space-sm);
  }

  .footer-logo {
    display: flex;
    align-items: center;
    gap: var(--space-sm);
  }

  .logo-wrapper {
    position: relative;
    display: flex;
    align-items: center;
    height: 72px;
    width: auto;
    flex-shrink: 0;
  }

  .logo-image {
    height: 100%;
    width: auto;
    max-height: 72px;
    object-fit: contain;
    filter: brightness(0) invert(1); /* Turns all dark/black logo colors to pure white silhouette */
  }

  .logo-fallback-visual {
    display: none;
    align-items: center;
    justify-content: center;
  }

  /* Legal Info block structure */
  .legal-info-container {
    display: flex;
    flex-direction: column;
    gap: 4px;
    margin: var(--space-xs) 0;
  }

  .legal-info-item {
    font-size: 0.75rem;
    line-height: 1.4;
    display: flex;
    gap: var(--space-xs);
  }

  .legal-label {
    font-family: var(--font-display);
    font-weight: 600;
    color: var(--color-text-light);
    text-transform: uppercase;
    font-size: 0.65rem;
    letter-spacing: 0.05em;
    min-width: 90px;
  }

  .legal-value {
    color: var(--color-text-muted-light);
  }

  .motto {
    font-family: var(--font-serif);
    font-style: italic;
    color: var(--color-text-light);
    font-size: 0.875rem;
    border-left: 2px solid var(--color-primary-light);
    padding-left: var(--space-xs);
    margin-top: var(--space-xs);
  }

  .footer-title {
    font-family: var(--font-display);
    font-size: 0.875rem;
    font-weight: 600;
    color: var(--color-text-light);
    text-transform: uppercase;
    letter-spacing: 0.1em;
    margin-bottom: var(--space-xs);
    position: relative;
    padding-bottom: var(--space-xs);
  }

  .footer-title::after {
    content: '';
    position: absolute;
    bottom: 0;
    left: 0;
    width: 30px;
    height: 2px;
    background-color: var(--color-primary-light);
  }

  .footer-links {
    list-style: none;
    display: flex;
    flex-direction: column;
    gap: var(--space-xs);
  }

  .footer-link {
    font-size: 0.875rem;
    color: var(--color-text-muted-light);
  }

  .footer-link:hover {
    color: var(--color-text-light);
    padding-left: var(--space-xs);
  }

  .footer-contacts {
    list-style: none;
    display: flex;
    flex-direction: column;
    gap: var(--space-md);
  }

  .contact-item {
    display: flex;
    gap: var(--space-sm);
    align-items: flex-start;
  }

  .contact-icon {
    flex-shrink: 0;
    color: var(--color-primary-light);
    margin-top: 3px;
  }

  .contact-label {
    font-family: var(--font-display);
    font-size: 0.65rem;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    color: var(--color-text-light);
    margin-bottom: 2px;
  }

  .contact-value {
    font-size: 0.875rem;
    color: var(--color-text-muted-light);
    display: block;
    line-height: 1.4;
  }

  .contact-value:hover {
    color: var(--color-text-light);
  }

  .address-value {
    font-size: 0.8rem;
  }

  /* Footer Bottom */
  .footer-bottom {
    margin-top: var(--space-xl);
    border-top: 1px solid rgba(255, 255, 255, 0.08);
    padding: var(--space-md) 0;
  }

  .bottom-container {
    display: flex;
    justify-content: space-between;
    align-items: center;
    gap: var(--space-md);
    flex-wrap: wrap;
  }

  .copyright {
    font-size: 0.75rem;
  }

  .ethical-notice {
    font-size: 0.7rem;
    font-style: italic;
    color: rgba(255, 255, 255, 0.4);
  }

  .developer-credit {
    font-size: 0.75rem;
    color: var(--color-text-muted-light);
  }

  .developer-link {
    color: var(--color-primary-light);
    font-weight: 500;
    text-decoration: none;
    transition: color var(--transition-fast);
  }

  .developer-link:hover {
    color: var(--color-text-light);
    text-decoration: underline;
  }

  @media (max-width: 768px) {
    .footer-grid {
      grid-template-columns: 1fr;
      gap: var(--space-xl);
    }

    .bottom-container {
      flex-direction: column;
      text-align: center;
      gap: var(--space-xs);
    }
  }
</style>
