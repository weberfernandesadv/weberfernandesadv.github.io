---
interface Props {
  title: string;
  summary: string;
  slug: string;
  icon: string;
}

const { title, summary, slug, icon } = Astro.props;
---

<a href={`/${slug}`} class="area-card">
  <div class="card-icon-container">
    {icon === 'home' && (
      <svg class="card-icon" viewBox="0 0 24 24" width="24" height="24" fill="none" stroke="currentColor" stroke-width="2">
        <path d="M3 9l9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z"/>
        <polyline points="9 22 9 12 15 12 15 22"/>
      </svg>
    )}
    {icon === 'shield' && (
      <svg class="card-icon" viewBox="0 0 24 24" width="24" height="24" fill="none" stroke="currentColor" stroke-width="2">
        <path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/>
      </svg>
    )}
    {icon === 'heart' && (
      <svg class="card-icon" viewBox="0 0 24 24" width="24" height="24" fill="none" stroke="currentColor" stroke-width="2">
        <path d="M20.84 4.61a5.5 5.5 0 0 0-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 0 0-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 0 0 0-7.78z"/>
      </svg>
    )}
    {icon === 'briefcase' && (
      <svg class="card-icon" viewBox="0 0 24 24" width="24" height="24" fill="none" stroke="currentColor" stroke-width="2">
        <rect x="2" y="7" width="20" height="14" rx="2" ry="2"/>
        <path d="M16 21V5a2 2 0 0 0-2-2h-4a2 2 0 0 0-2 2v16"/>
      </svg>
    )}
    {icon === 'scale' && (
      <svg class="card-icon" viewBox="0 0 24 24" width="24" height="24" fill="none" stroke="currentColor" stroke-width="2">
        <line x1="12" y1="2" x2="12" y2="22"/>
        <line x1="5" y1="7" x2="19" y2="7"/>
        <path d="M5 7c0 5 2.5 7 2.5 7s2.5-2 2.5-7"/>
        <path d="M14 7c0 5 2.5 7 2.5 7s2.5-2 2.5-7"/>
      </svg>
    )}
    {icon === 'users' && (
      <svg class="card-icon" viewBox="0 0 24 24" width="24" height="24" fill="none" stroke="currentColor" stroke-width="2">
        <path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/>
        <circle cx="9" cy="7" r="4"/>
        <path d="M23 21v-2a4 4 0 0 0-3-3.87"/>
        <path d="M16 3.13a4 4 0 0 1 0 7.75"/>
      </svg>
    )}
    {icon === 'folder-open' && (
      <svg class="card-icon" viewBox="0 0 24 24" width="24" height="24" fill="none" stroke="currentColor" stroke-width="2">
        <path d="M22 19a2 2 0 0 1-2 2H4a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h5l2 3h9a2 2 0 0 1 2 2z"/>
        <polygon points="12 11 17 11 17 16 12 16"/>
      </svg>
    )}
    {icon === 'file-text' && (
      <svg class="card-icon" viewBox="0 0 24 24" width="24" height="24" fill="none" stroke="currentColor" stroke-width="2">
        <path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/>
        <polyline points="14 2 14 8 20 8"/>
        <line x1="16" y1="13" x2="8" y2="13"/>
        <line x1="16" y1="17" x2="8" y2="17"/>
        <polyline points="10 9 9 9 8 9"/>
      </svg>
    )}
    {icon === 'shopping-bag' && (
      <svg class="card-icon" viewBox="0 0 24 24" width="24" height="24" fill="none" stroke="currentColor" stroke-width="2">
        <path d="M6 2L3 6v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2V6l-3-4z"/>
        <line x1="3" y1="6" x2="21" y2="6"/>
        <path d="M16 10a4 4 0 0 1-8 0"/>
      </svg>
    )}
    {icon === 'gavel' && (
      <svg class="card-icon" viewBox="0 0 24 24" width="24" height="24" fill="none" stroke="currentColor" stroke-width="2">
        <path d="M14 13L4.5 22.5c-.8.8-2 .8-2.8 0s-.8-2 0-2.8L11 10"/>
        <path d="M16 2l6 6-8 8-6-6 8-8z"/>
        <path d="M9 13l2 2"/>
        <path d="M17 5l2 2"/>
      </svg>
    )}
    {icon === 'globe' && (
      <svg class="card-icon" viewBox="0 0 24 24" width="24" height="24" fill="none" stroke="currentColor" stroke-width="2">
        <circle cx="12" cy="12" r="10"/>
        <line x1="2" y1="12" x2="22" y2="12"/>
        <path d="M12 2a15.3 15.3 0 0 1 4 10 15.3 15.3 0 0 1-4 10 15.3 15.3 0 0 1-4-10 15.3 15.3 0 0 1 4-10z"/>
      </svg>
    )}
    {icon === 'award' && (
      <svg class="card-icon" viewBox="0 0 24 24" width="24" height="24" fill="none" stroke="currentColor" stroke-width="2">
        <circle cx="12" cy="8" r="7"/>
        <polyline points="8.21 13.89 7 23 12 20 17 23 15.79 13.88"/>
      </svg>
    )}
  </div>
  <div class="card-body">
    <h3 class="card-title">{title}</h3>
    <p class="card-text">{summary}</p>
    <span class="card-link-action">
      Saber mais
      <!-- Arrow Right Icon -->
      <svg class="arrow-icon" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
        <line x1="5" y1="12" x2="19" y2="12"/>
        <polyline points="12 5 19 12 12 19"/>
      </svg>
    </span>
  </div>
</a>

<style>
  .area-card {
    display: flex;
    flex-direction: column;
    padding: var(--space-md);
    background-color: var(--color-bg-light);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-md);
    box-shadow: var(--shadow-sm);
    transition: all var(--transition-normal);
    height: 100%;
    position: relative;
    overflow: hidden;
  }

  .area-card::before {
    content: '';
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 3px;
    background-color: transparent;
    transition: background-color var(--transition-normal);
  }

  .area-card:hover {
    transform: translateY(-5px);
    border-color: rgba(107, 0, 119, 0.2);
    box-shadow: var(--shadow-lg);
  }

  .area-card:hover::before {
    background-color: var(--color-primary);
  }

  .card-icon-container {
    width: 48px;
    height: 48px;
    border-radius: var(--radius-sm);
    background-color: rgba(107, 0, 119, 0.05);
    color: var(--color-primary);
    display: flex;
    align-items: center;
    justify-content: center;
    margin-bottom: var(--space-sm);
    transition: all var(--transition-normal);
  }

  .area-card:hover .card-icon-container {
    background-color: var(--color-primary);
    color: var(--color-bg-light);
    transform: scale(1.05);
  }

  .card-icon {
    transition: transform var(--transition-normal);
  }

  .card-body {
    display: flex;
    flex-direction: column;
    flex-grow: 1;
  }

  .card-title {
    font-size: 1.15rem;
    color: var(--color-bg-dark);
    margin-bottom: var(--space-xs);
    font-family: var(--font-display);
    text-transform: none;
    letter-spacing: normal;
  }

  .card-text {
    font-size: 0.875rem;
    color: var(--color-text-muted);
    margin-bottom: var(--space-md);
    flex-grow: 1;
    line-height: 1.5;
  }

  .card-link-action {
    display: inline-flex;
    align-items: center;
    gap: var(--space-xs);
    font-family: var(--font-display);
    font-size: 0.75rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    color: var(--color-primary);
  }

  .arrow-icon {
    transition: transform var(--transition-fast);
  }

  .area-card:hover .arrow-icon {
    transform: translateX(4px);
  }
</style>
