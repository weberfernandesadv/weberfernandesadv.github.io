---
interface Props {
  title: string;
  subtitle?: string;
  tagline?: string;
  ctaText?: string;
  ctaLink?: string;
}

const { title, subtitle, tagline, ctaText, ctaLink } = Astro.props;
---

<section class="page-hero">
  <!-- Subtle geometric color lights representing logo accent colors -->
  <div class="hero-light-accents">
    <div class="light-purple"></div>
    <div class="light-green"></div>
  </div>
  
  <div class="container hero-container">
    <div class="hero-content slide-up">
      {tagline && <span class="hero-tagline">{tagline}</span>}
      <h1 class="hero-title">{title}</h1>
      {subtitle && <p class="hero-subtitle">{subtitle}</p>}
      
      {ctaText && ctaLink && (
        <div class="hero-actions">
          <a href={ctaLink} class="btn btn-outline-white">
            {ctaText}
            <!-- Arrow Right Icon -->
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class="arrow">
              <line x1="5" y1="12" x2="19" y2="12"/>
              <polyline points="12 5 19 12 12 19"/>
            </svg>
          </a>
        </div>
      )}
    </div>
  </div>
</section>

<style>
  .page-hero {
    position: relative;
    padding: var(--space-xxl) 0;
    min-height: 400px;
    background: linear-gradient(135deg, #1E0024 0%, var(--color-bg-dark) 100%);
    display: flex;
    align-items: center;
    overflow: hidden;
    margin-top: 80px; /* Offset fixed header */
  }

  .page-hero::before {
    content: '';
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    background: radial-gradient(circle at 70% 30%, rgba(107, 0, 119, 0.15) 0%, transparent 60%);
    z-index: 1;
  }

  .page-hero::after {
    content: '';
    position: absolute;
    bottom: 0;
    left: 0;
    width: 100%;
    height: 1px;
    background: linear-gradient(90deg, transparent 0%, var(--color-primary) 50%, transparent 100%);
    z-index: 2;
  }

  .hero-light-accents {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    z-index: 1;
    pointer-events: none;
  }

  .light-purple {
    position: absolute;
    top: 20%;
    left: -10%;
    width: 400px;
    height: 400px;
    background: radial-gradient(circle, rgba(107, 0, 119, 0.1) 0%, rgba(107, 0, 119, 0) 70%);
    filter: blur(50px);
  }

  .light-green {
    position: absolute;
    bottom: -10%;
    right: -5%;
    width: 300px;
    height: 300px;
    background: radial-gradient(circle, rgba(46, 125, 50, 0.04) 0%, rgba(46, 125, 50, 0) 70%);
    filter: blur(50px);
  }

  .hero-container {
    position: relative;
    z-index: 3;
  }

  .hero-content {
    max-width: 800px;
  }

  .hero-tagline {
    font-family: var(--font-display);
    font-size: 0.8rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.2em;
    color: var(--color-primary-light);
    display: inline-block;
    margin-bottom: var(--space-sm);
  }

  .hero-title {
    font-size: 3.5rem;
    color: #D4AF37; /* Dourado prestigioso da logomarca */
    margin-bottom: var(--space-sm);
    line-height: 1.15;
    font-weight: 600;
  }

  .hero-subtitle {
    font-size: 1.25rem;
    color: var(--color-text-muted-light);
    font-weight: 300;
    margin-bottom: var(--space-lg);
    line-height: 1.5;
  }

  .hero-actions {
    display: flex;
    gap: var(--space-md);
  }

  .hero-actions .btn {
    display: inline-flex;
    align-items: center;
    gap: var(--space-xs);
  }

  .hero-actions .btn .arrow {
    transition: transform var(--transition-fast);
  }

  .hero-actions .btn:hover .arrow {
    transform: translateX(4px);
  }

  @media (max-width: 768px) {
    .page-hero {
      padding: var(--space-xl) 0;
      min-height: 320px;
    }

    .hero-title {
      font-size: 2.25rem;
    }

    .hero-subtitle {
      font-size: 1.05rem;
    }
  }
</style>
