---
interface Props {
  title: string;
  subtitle?: string;
  align?: 'left' | 'center';
}

const { title, subtitle, align = 'center' } = Astro.props;
---

<div class={`section-title-container align-${align}`}>
  <h2 class="section-title-heading">{title}</h2>
  {subtitle && <p class="section-title-subtitle">{subtitle}</p>}
  <div class="divider-visual">
    <span class="divider-line"></span>
    <span class="divider-dot"></span>
    <span class="divider-line"></span>
  </div>
</div>

<style>
  .section-title-container {
    margin-bottom: var(--space-xl);
    display: flex;
    flex-direction: column;
  }

  .align-center {
    align-items: center;
    text-align: center;
  }

  .align-left {
    align-items: flex-start;
    text-align: left;
  }

  .section-title-heading {
    font-size: 2.25rem;
    color: var(--color-bg-dark);
    margin-bottom: var(--space-xs);
    position: relative;
  }

  .section-title-subtitle {
    font-size: 1.1rem;
    color: var(--color-text-muted);
    max-width: 650px;
    font-weight: 300;
  }

  .divider-visual {
    display: flex;
    align-items: center;
    gap: var(--space-xs);
    margin-top: var(--space-sm);
    width: 150px;
  }

  .align-left .divider-visual {
    justify-content: flex-start;
  }

  .align-center .divider-visual {
    justify-content: center;
  }

  .divider-line {
    flex-grow: 1;
    height: 1px;
    background-color: var(--color-border);
  }

  .divider-dot {
    width: 6px;
    height: 6px;
    background-color: var(--color-primary);
    border-radius: var(--radius-full);
    position: relative;
  }

  .divider-dot::after {
    content: '';
    position: absolute;
    top: -3px;
    left: -3px;
    width: 12px;
    height: 12px;
    border: 1px solid var(--color-primary-light);
    border-radius: var(--radius-full);
    opacity: 0.5;
  }

  @media (max-width: 768px) {
    .section-title-heading {
      font-size: 1.75rem;
    }
    
    .section-title-subtitle {
      font-size: 0.95rem;
    }
  }
</style>
