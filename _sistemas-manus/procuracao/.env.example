# Banco de dados MySQL / MariaDB (Drizzle)
DATABASE_URL=mysql://usuario:senha@localhost:3306/nome_banco

# Autenticação JWT (Chave secreta para assinar cookies locais)
JWT_SECRET=sua_chave_secreta_jwt_de_64_caracteres

# Credenciais Iniciais do Administrador (seed automático na inicialização)
ADMIN_EMAIL=wolrickwolf@gmail.com
ADMIN_PASSWORD=senha_inicial_do_advogado

# Configuração de Ambiente
NODE_ENV=development
PORT=3000

# Configurações de Envio de E-mail (nodemailer - SMTP)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=wolrickwolf@gmail.com
SMTP_PASS=sua_senha_de_aplicativo_gmail_aqui

# Configurações de Armazenamento de Arquivos
STORAGE_DRIVER=local
UPLOAD_DIR=./uploads

# Variáveis legadas do Manus OAuth (não utilizadas na autenticação local)
VITE_APP_ID=seu_app_id_manus
OAUTH_SERVER_URL=https://api.manus.im
VITE_OAUTH_PORTAL_URL=https://manus.im
